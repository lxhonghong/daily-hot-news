# ===== LLM API 配置 =====
# GLM-5.1（Anthropic SDK 兼容格式）
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://www.huolilink.com
ANTHROPIC_MODEL=GLM-5.1

# ===== CurrentsAPI 配置 =====
CURRENTS_API_KEY=your_currents_api_key_here

# ===== RSSHub 配置 =====
RSSHUB_BASE_URL=http://localhost:1200

# ===== 知乎 Cookie（获取全文需要）=====
ZHIHU_COOKIES=your_zhihu_cookie_here

# ===== Git 配置 =====
# 用于自动推送生成的页面
GIT_REPO_DIR=/Users/lx/Personal/daily-hot-news

# ===== 通知配置 =====
# 失败时是否弹 macOS 通知
ENABLE_MACOS_NOTIFICATION=true

# ===== GitHub API Token（可选，提升速率限制）=====
# 不配置也能用，每分钟 10 次请求，每日够用
GITHUB_TOKEN=
